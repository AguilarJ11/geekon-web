generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  banner        String?
  bio           String?
  city          String?
  instagram     String?
  discord       String?
  tiktok        String?
  twitter       String?
  interests     String[] @default([])
  password      String?
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  badges      UserBadge[]
  submissions FormSubmission[]
}

enum FieldType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  NUMBER
  SELECT
  RADIO
  CHECKBOX
  DATE
}

enum FormCategory {
  ARTE
  STAND
  COSPLAY
  TORNEO
  ACTIVIDAD
  OTRO
}

model Form {
  id          String       @id @default(cuid())
  title       String
  description String?
  slug        String       @unique
  category    FormCategory @default(OTRO)
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  fields      FormField[]
  submissions FormSubmission[]
}

model FormField {
  id          String    @id @default(cuid())
  formId      String
  type        FieldType
  label       String
  placeholder String?
  required    Boolean   @default(false)
  order       Int
  options     String?

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, order])
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model FormSubmission {
  id        String           @id @default(cuid())
  formId    String
  userId    String
  data      Json
  status    SubmissionStatus @default(PENDING)
  createdAt DateTime         @default(now())

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([formId, userId])
}

model Badge {
  id          String    @id @default(cuid())
  name        String    @unique
  description String
  icon        String
  edition     String?
  createdAt   DateTime  @default(now())

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}
