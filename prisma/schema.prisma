generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  // Handle único, distinto del nombre para mostrar. Nulo hasta que el usuario
  // lo elige en el onboarding obligatorio post-login (ver /elegir-usuario);
  // el middleware bloquea el resto del sitio hasta que lo complete. Se usa
  // como slug del perfil público (/perfil/[username]).
  username            String?   @unique
  name                String?
  email               String    @unique
  showEmail           Boolean   @default(false)
  showFriendsPublicly Boolean   @default(false)
  emailVerified       DateTime?
  image               String?
  banner              String?
  bio                 String?
  city                String?
  instagram           String?
  discord             String?
  tiktok              String?
  twitter             String?
  interests           String[]  @default([])
  password            String?
  role                String    @default("USER")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  badges           UserBadge[]
  submissions      FormSubmission[]
  ownedForms       Form[]           @relation("FormOwner")
  albums           Album[]          @relation("AlbumUploader")
  sentRequests     Friendship[]     @relation("FriendRequester")
  receivedRequests Friendship[]     @relation("FriendAddressee")
}

enum FieldType {
  TEXT
  TEXTAREA
  EMAIL
  PHONE
  NUMBER
  SELECT
  RADIO
  CHECKBOX
  DATE
}

enum FormCategory {
  ARTE
  STAND
  COSPLAY
  TORNEO
  ACTIVIDAD
  CHARLA_TALLER
  OTRO
}

model Form {
  id          String       @id @default(cuid())
  title       String
  description String?
  slug        String       @unique
  category    FormCategory @default(OTRO)
  edition     String?
  ownerId     String?
  isPublished Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Solo se usan en formularios de categoría STAND. Sirven para mostrarle
  // el plazo a quien se postula y, más adelante, para disparar recordatorios
  // (WhatsApp u otro canal) unos días antes de cada vencimiento.
  depositDueDate     DateTime?
  fullPaymentDueDate DateTime?

  owner        User?            @relation("FormOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  fields       FormField[]
  submissions  FormSubmission[]
  standOptions StandOption[]
}

// Tipos de stand que un formulario de categoría STAND deja elegir al
// postularse (ej. "Stand chico" · 2m² · $500). El precio y metraje se
// congelan como snapshot en FormSubmission.data al enviar, para que
// editar/borrar una opción no altere postulaciones ya hechas.
model StandOption {
  id      String @id @default(cuid())
  formId  String
  label   String
  metraje String
  precio  Float
  order   Int    @default(0)

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, order])
}

model FormField {
  id          String    @id @default(cuid())
  formId      String
  type        FieldType
  label       String
  placeholder String?
  required    Boolean   @default(false)
  order       Int
  options     String?

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, order])
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model FormSubmission {
  id        String           @id @default(cuid())
  formId    String
  userId    String
  data      Json
  status    SubmissionStatus @default(PENDING)
  isWinner  Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Marca cuándo se mandó el recordatorio por mail de cada vencimiento
  // (Stand Comercial), para no volver a mandarlo todos los días.
  depositReminderSentAt     DateTime?
  fullPaymentReminderSentAt DateTime?

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([formId, userId])
}

model Badge {
  id          String    @id @default(cuid())
  name        String    @unique
  description String
  icon        String
  edition     String?
  createdAt   DateTime  @default(now())

  users UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

enum AlbumStatus {
  PENDING
  APPROVED
}

// Álbumes de fotos de cada edición de GeekOn!. Solo ADMIN y usuarios con rol
// FOTOGRAFO pueden crear álbumes y subir fotos (ver requireGalleryAccess en
// lib/auth.ts). El álbum entra como PENDING y recién se ve en la galería
// pública cuando un administrador lo aprueba (aprobación en bloque, ver
// PATCH /api/gallery/albums/[id]) — puede también rechazar fotos puntuales
// antes de aprobar el resto del álbum.
model Album {
  id           String      @id @default(cuid())
  title        String
  edition      String?
  description  String?
  coverUrl     String?
  status       AlbumStatus @default(PENDING)
  uploadedById String?
  createdAt    DateTime    @default(now())

  uploadedBy User?   @relation("AlbumUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  photos     Photo[]

  @@index([createdAt])
}

enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

// Toda foto entra como PENDING, sin importar quién la suba (admin o
// fotógrafo): solo se muestra en la galería pública una vez que un
// administrador aprueba el álbum completo. Rechazar una foto puntual
// requiere especificar el motivo (rejectionReason).
model Photo {
  id               String      @id @default(cuid())
  albumId          String
  url              String
  publicId         String?
  order            Int         @default(0)
  status           PhotoStatus @default(PENDING)
  rejectionReason  String?
  createdAt        DateTime    @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId, order])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

// Una fila por par de usuarios. Si quien recibe rechaza, se borra la fila
// (no hay estado REJECTED) para que se pueda volver a mandar una solicitud
// más adelante sin quedar bloqueado para siempre.
model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  respondedAt DateTime?

  requester User @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@index([addresseeId, status])
}
